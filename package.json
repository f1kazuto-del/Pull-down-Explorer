{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=server.cjs --external:electron --external:adm-zip --external:vite --external:esbuild --log-override:empty-import-meta=silent --log-override:require-resolve-not-external=silent --log-override:empty-glob=silent",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.example.file-explorer",
    "productName": "Pull-down Explorer",
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "f1kazuto",
        "repo": "Pull-down-Explorer"
      }
    ],
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "server.cjs",
      "loading.html",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "main": "electron-main.cjs",
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
